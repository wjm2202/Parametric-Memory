FROM node:20-alpine AS builder
RUN apk add --no-cache python3 make g++
WORKDIR /app
COPY package*.json tsconfig.json tsconfig.mcp.json ./
RUN npm install
COPY . .
RUN npx tsc -p tsconfig.mcp.json

FROM node:20-alpine
ENV NODE_OPTIONS=--max-old-space-size=256
RUN apk add --no-cache libstdc++
WORKDIR /app
COPY package*.json ./
RUN npm install --only=production
COPY --from=builder /app/dist-mcp ./dist-mcp
COPY .env* ./
EXPOSE 3001
CMD ["node", "dist-mcp/tools/mcp/mmpm_mcp_http.js"]
