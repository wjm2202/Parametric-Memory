# ── Dependencies ──────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────
dist/
*.js.map
*.d.ts.map

# ── LevelDB / runtime data ────────────────────────────────────────────
wal/
mmpm-db/
mmpm-test-smoke-db*/
mmpm-demo-db/
test-shard-db*/
test-*-db*/
mmpm-harness-cli-db*/

# ── Environment files ─────────────────────────────────────────────────
# Block ALL .env variants — they may contain secrets
.env
.env.*
# Exception: .env.example is safe documentation — always commit it
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Test artefacts ────────────────────────────────────────────────────
coverage/
.nyc_output/
vitest-results/
# Root-level WAL files left by test runs
*.wal
# Temp test DB directories and debug dirs
test-debug-g3/
# Linux FUSE hidden files (CoWork / FUSE mounts)
.fuse_hidden*
# Planning / scratch documents not part of the committed source
FEATURE_ROADMAP.md
SPRINT_12_PLAN.md

# ── Benchmark artifacts ─────────────────────────────────────────────────────
tools/harness/results/**/

# ── Docker ────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfile ARE committed)

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.orig