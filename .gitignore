# ── Dependencies ──────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────
dist/
*.js.map
*.d.ts.map

# ── LevelDB / runtime data ────────────────────────────────────────────
# All runtime DB and WAL files live under DB_BASE_PATH (default: ./data)
data/
# Legacy path (pre-v1.1 default)
mmpm-db/
# Harness and smoke-test databases (still written to cwd by some tools)
mmpm-test-smoke-db*/
mmpm-demo-db/
mmpm-harness-cli-db*/

# ── Environment files ─────────────────────────────────────────────────
# Block ALL .env variants — they may contain secrets
.env
.env.*
# Exception: .env.example is safe documentation — always commit it
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Test artefacts ────────────────────────────────────────────────────
coverage/
.nyc_output/
vitest-results/
# WAL files (some harness modes write these to cwd)
*.wal
# Linux FUSE hidden files (CoWork / FUSE mounts)
.fuse_hidden*
# ── Internal planning / scratch documents — not part of public source
FEATURE_ROADMAP.md
SPRINT_*.md
CHECKLIST.md
BUSINESS_PLAN.md
LAUNCH_ORCHESTRATION.md
OPTIMIZATION_REVIEW.md
TECHNOLOGY_BUSINESS_SCIENTIFIC_REVIEW.md
ACCOUNT_SETUP_GUIDE.md
UPDATED_DESIGN_DOC.md
SCIENTIFIC_PAPER_DRAFT.md
TOKEN_OPTIMIZATION.md
design_doc.txt
memory.md
.github/AGENT_SPRINT_BOARD.md
docs/GITHUB_PROFILE_README.md
docs/README_AGENT.md
docs/README_PUBLIC_ARCHIVE.md

# ── Benchmark artifacts ─────────────────────────────────────────────────────
tools/harness/results/**/

# ── Docker ────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfile ARE committed)

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.orig