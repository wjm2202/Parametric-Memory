# ═══════════════════════════════════════════════════════════════════════
# MMPM — Environment Variable Reference
#
# This file is committed to source control as safe documentation.
# It contains NO real secrets — only example / default values.
#
# Usage:
#   cp .env.example .env          # production
#   cp .env.example .env.test     # test / CI
# Then edit the copy with your real values.
# ═══════════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── HTTP server ───────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Sharding ──────────────────────────────────────────────────────────
# Number of consistent-hash shards (power of 2 recommended: 2, 4, 8 …)
SHARD_COUNT=4

# ── LevelDB ───────────────────────────────────────────────────────────
# Base directory — one sub-folder is created per shard automatically
DB_BASE_PATH=./mmpm-db

# ── Initial data pool ─────────────────────────────────────────────────
# Comma-separated atoms pre-loaded into the cluster at startup
MMPM_INITIAL_DATA=NodeA,NodeB,NodeC,NodeD,NodeE,NodeF
# Optional JSON file path containing ["atom1", "atom2", ...]
# Takes precedence over MMPM_INITIAL_DATA when set.
MMPM_ATOM_FILE=

# ── Ingestion pipeline ────────────────────────────────────────────────
# Queue flushes when this batch size is reached.
INGEST_BATCH_SIZE=100
# Time-based flush interval (ms) for queued atoms.
INGEST_FLUSH_MS=1000

# ── Commit scheduling ──────────────────────────────────────────────────
# Per-shard auto-commit when pending writes reach this threshold.
# Leave blank to use code default.
MMPM_COMMIT_THRESHOLD=
# Per-shard periodic auto-commit interval in milliseconds (0/blank disables).
MMPM_COMMIT_INTERVAL_MS=

# ── Backpressure ───────────────────────────────────────────────────────
# Reject /atoms when projected pending writes exceed this high-water mark.
MMPM_PENDING_HIGH_WATER_MARK=1000
# Retry-After value (seconds) sent with backpressure 503 responses.
MMPM_BACKPRESSURE_RETRY_AFTER_SEC=1

# ── WAL / durability ───────────────────────────────────────────────────
# WAL compaction threshold in bytes.
MMPM_WAL_COMPACT_THRESHOLD_BYTES=262144

# ── Authentication ────────────────────────────────────────────────────
# API key enforced on /access and /train endpoints.
# Leave blank to disable authentication entirely.
MMPM_API_KEY=replace-with-a-strong-random-secret

# ── Smoke test helper ─────────────────────────────────────────────────
# Base URL used by test-api.sh and run-smoke.sh
MMPM_BASE_URL=http://localhost:3000

# ── MCP adapter (tools/mcp) ───────────────────────────────────────────
# Base URL the MCP adapter uses to call this HTTP API.
MMPM_MCP_BASE_URL=http://127.0.0.1:3000
# Optional MCP-specific API key; falls back to MMPM_API_KEY when blank.
MMPM_MCP_API_KEY=
# 0 = hide mutating MCP tools, 1 = expose mutating MCP tools.
MMPM_MCP_ENABLE_MUTATIONS=0
# 0 = hide semantic MCP tools, 1 = expose memory_search/memory_context tools.
# Note: memory_search requires POST /search support.
MMPM_MCP_ENABLE_SEMANTIC_TOOLS=0

# ── Grafana ───────────────────────────────────────────────────────────
# Credentials for the Grafana admin user.
# These are picked up by docker-compose.yml via env substitution.
# IMPORTANT: change the password before any public/cloud deployment.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
GF_AUTH_DISABLE_LOGIN_FORM=false
# Prevents 401 noise on /api/live/ws from unauthenticated browser requests.
GF_AUTH_ANONYMOUS_ENABLED=false
# Quiet the per-request context logger (responsible for the /api/live/ws 401 lines)
# without disabling Grafana Live, which is needed for Unified Alerting.
GF_LOG_FILTERS=context:warn
