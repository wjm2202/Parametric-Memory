# ── Parametric-Memory Configuration ───────────────────────────────────────────
# Copy this file to .env before starting the server:
#   cp .env.example .env
#
# All variables are optional — sensible defaults are noted inline.

# ── CORE SERVER ────────────────────────────────────────────────────────────────

# HTTP server port (default: 3000)
PORT=3000

# Host to bind to.
# SECURITY: 127.0.0.1 (loopback only) is the safe default — the server is not
# reachable from other machines and the API key cannot be sniffed over the
# network. Only change to 0.0.0.0 when running behind a TLS-terminating reverse
# proxy (nginx, Caddy, etc.) that handles auth or mTLS at the edge.
# (default: 127.0.0.1)
HOST=127.0.0.1

# LevelDB storage directory — MUST be outside the git repo so your data
# survives git operations, docker rebuilds, and fresh clones.
# Leading ~ is expanded by the server, so this is safe on all platforms.
# (default when unset: ~/.mmpm/data)
DB_BASE_PATH=~/.mmpm/data

# Number of LevelDB shards — higher = more parallelism, more file handles
# (default: 4)
SHARD_COUNT=4

# ── AUTHENTICATION ─────────────────────────────────────────────────────────────

# API key for Bearer token auth. Leave empty to disable auth (not recommended
# in production). Generate a strong key with: openssl rand -hex 32
MMPM_API_KEY=change-me-before-production

# S16-8: Per-client named API keys (optional, comma-separated name:key pairs).
# When set, each key is associated with a client name that appears in audit logs,
# making it easy to identify which integration performed each operation.
# Keys listed here are accepted *in addition to* MMPM_API_KEY.
# Example: MMPM_API_KEYS=mcp:key1,backup:key2,claude:key3
# Generate keys with: openssl rand -hex 32
# MMPM_API_KEYS=

# ── LOGGING ────────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal | silent
# (default: info)
LOG_LEVEL=info

# ── WRITE POLICY ───────────────────────────────────────────────────────────────

# Controls whether writes are auto-committed or require review:
#   auto-write       — atoms are committed immediately (default)
#   review-required  — atoms queue for manual review before committing
#   never-store      — all writes are rejected (read-only mode)
WRITE_POLICY=auto-write

# ── COMMIT TUNING ──────────────────────────────────────────────────────────────

# Number of pending atoms before triggering an auto-commit (default: 50)
# MMPM_COMMIT_THRESHOLD=50

# Milliseconds between periodic auto-commits regardless of threshold
# (default: 5000)
# MMPM_COMMIT_INTERVAL_MS=5000

# Max atoms that can sit in the pending queue before backpressure kicks in
# (default: 500)
# MMPM_PENDING_HIGH_WATER_MARK=500

# Seconds to tell callers to retry when backpressure limit is hit (default: 5)
# MMPM_BACKPRESSURE_RETRY_AFTER_SEC=5

# ── WAL & SHARD TUNING ─────────────────────────────────────────────────────────

# WAL file size (bytes) before compaction is triggered (default: 10485760 = 10 MB)
# MMPM_WAL_COMPACT_THRESHOLD_BYTES=10485760

# Markov confidence half-life — how quickly transition weights decay with
# disuse, in milliseconds (default: 604800000 = 7 days)
# MMPM_CONFIDENCE_HALF_LIFE_MS=604800000

# ── INGEST PIPELINE ────────────────────────────────────────────────────────────

# Batch size for the write-ingest pipeline (default: 100)
# INGEST_BATCH_SIZE=100

# Flush interval for the ingest pipeline in milliseconds (default: 1000)
# INGEST_FLUSH_MS=1000

# ── SEED DATA ──────────────────────────────────────────────────────────────────

# Path to a JSON file (array of v1 atom strings) to load at startup.
# Use hub atoms as Markov chain entry points — train edges FROM them to
# domain-specific atoms so every session has a clear navigation root.
# The bundled seeds.json provides: hub_session, hub_facts, hub_state,
# hub_procedures, hub_relations, hub_events.
MMPM_ATOM_FILE=./seeds.json

# Comma-separated atom strings to load on server start (optional, legacy).
# Prefer MMPM_ATOM_FILE for anything beyond a single test atom.
# MMPM_INITIAL_DATA=v1.fact.example_atom,v1.state.server_started

# ── INTEGRATIONS ───────────────────────────────────────────────────────────────

# Webhook URL — when set, MMPM POSTs a JSON event after each commit.
# Body: { event, version, atomCount, timestamp, namespace }
# Fire-and-forget, 5s timeout, no retry on failure.
# MMPM_WEBHOOK_URL=https://your-service.example.com/mmpm-events

# ── MCP SERVER (npm run mcp:serve) ────────────────────────────────────────────

# Base URL of the MMPM HTTP server that the MCP process talks to
# (default: http://127.0.0.1:3000)
# MMPM_MCP_BASE_URL=http://127.0.0.1:3000

# API key for the MCP server — falls back to MMPM_API_KEY if not set
# MMPM_MCP_API_KEY=

# Set to "1" to enable write/mutation tools in the MCP server (default: off)
# MMPM_MCP_ENABLE_MUTATIONS=0

# Set to "1" to enable semantic/embedding tools in the MCP server (default: off)
# MMPM_MCP_ENABLE_SEMANTIC_TOOLS=0

# ── SECURITY ───────────────────────────────────────────────────────────────────

# Expose /metrics without authentication for Prometheus scrapers that cannot
# send Authorization headers. SECURITY: do not set in production unless the
# scraper endpoint is network-isolated or behind mTLS.
# (default: 0 — /metrics requires the same Bearer token as all other endpoints)
# MMPM_METRICS_PUBLIC=0

# Block writes of atoms whose values match common secret patterns
# (password, api_key, token, private_key, secret, credential).
# Returns HTTP 422 when a matching atom is submitted.
# (default: 0 — off; recommended: 1 for production)
# MMPM_BLOCK_SECRET_ATOMS=0
