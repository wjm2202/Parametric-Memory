{
  "name": "markov-merkle-memory",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test:efficiency": "ts-node src/index.ts",
    "docker:build": "docker build -t markov-merkle-memory .",
    "docker:run": "docker run -p 3000:3000 markov-merkle-memory",
    "clean": "rm -rf dist",
    "cleanup": "ts-node tools/harness/cleanup.ts",
    "test": "vitest run",
    "posttest": "npm run cleanup",
    "test:watch": "vitest",
    "test:smoke": "bash run-smoke.sh",
    "test:sharding": "ts-node src/test-sharding.ts",
    "bench:report": "ts-node tools/harness/report.ts",
    "bench:exporter": "ts-node tools/harness/report.ts --serve --port 9466 --report-file tools/harness/results/latest.json",
    "bench:run": "ts-node tools/harness/cli.ts --preset smoke --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run": "npm run cleanup",
    "bench:run:api": "ts-node tools/harness/cli.ts --preset smoke --api --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run:api": "npm run cleanup",
    "bench:run:concurrent": "ts-node tools/harness/cli.ts --preset concurrent --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "bench:grafana": "bash tools/harness/open-grafana.sh",
    "bench:ci:api": "bash tools/harness/ci-bench-api.sh",
    "bench:track": "ts-node tools/harness/track.ts",
    "bench:track:save": "ts-node tools/harness/track.ts save --report-file tools/harness/results/latest.json --results-dir tools/harness/results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "classic-level": "^3.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "prom-client": "^15.1.3"
  }
}