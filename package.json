{
  "name": "parametric-memory",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:test",
    "sprint:complete": "npm run typecheck:all",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test:efficiency": "ts-node src/index.ts",
    "docker:build": "docker build -t parametric-memory .",
    "docker:run": "docker run -p 3000:3000 parametric-memory",
    "clean": "rm -rf dist",
    "cleanup": "ts-node tools/harness/cleanup.ts",
    "test": "vitest run",
    "posttest": "npm run cleanup",
    "test:watch": "vitest",
    "test:smoke": "bash scripts/smoke-test.sh",
    "test:sharding": "ts-node src/test-sharding.ts",
    "bench:report": "ts-node tools/harness/report.ts",
    "bench:exporter": "ts-node tools/harness/report.ts --serve --port 9466 --report-file tools/harness/results/latest.json",
    "bench:run": "ts-node tools/harness/cli.ts --preset smoke --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run": "npm run cleanup",
    "bench:run:api": "ts-node tools/harness/cli.ts --preset smoke --api --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run:api": "npm run cleanup",
    "bench:slo:check": "ts-node tools/harness/slo_gate.ts --report-file tools/harness/results/latest.json",
    "bench:run:concurrent": "ts-node tools/harness/cli.ts --preset concurrent --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "bench:run:realworld": "ts-node tools/harness/real_world_case.ts --preset medium --shards 8 --out tools/harness/results/realworld-latest.json --prom-out tools/harness/results/realworld-latest.prom",
    "bench:run:realworld:large": "ts-node tools/harness/real_world_case.ts --preset large --shards 16 --out tools/harness/results/realworld-large.json --prom-out tools/harness/results/realworld-large.prom",
    "bench:pilot:ecommerce": "ts-node tools/harness/domain_pilot.ts --out tools/harness/results/domain-pilot-ecommerce.json",
    "bench:pilot:ecommerce:check": "npm run bench:pilot:ecommerce",
    "bench:continuous": "ts-node tools/harness/continuous_client.ts --profile balanced --duration-ms 60000 --target-ops 120 --concurrency 8",
    "bench:continuous:policy": "ts-node tools/harness/continuous_client.ts --profile policy-stress --duration-ms 60000 --target-ops 120 --concurrency 8",
    "bench:continuous:live": "ts-node tools/harness/continuous_client.ts --profile balanced --duration-ms 3600000 --target-ops 120 --concurrency 8 --metrics-port 9470 --metrics-host 0.0.0.0",
    "bench:inspect:db": "ts-node tools/harness/inspect_db.ts --db ./mmpm-db --shard 0",
    "bench:inspect:tree": "ts-node tools/harness/inspect_db.ts --db ./mmpm-db --shard 0 --atom RW_Boot_A --depth 3 --branch 4 --out tools/harness/results/sparse-tree.mmd",
    "bench:grafana": "bash tools/harness/open-grafana.sh",
    "bench:ci:api": "bash tools/harness/ci-bench-api.sh",
    "bench:track": "ts-node tools/harness/track.ts",
    "bench:track:save": "ts-node tools/harness/track.ts save --report-file tools/harness/results/latest.json --results-dir tools/harness/results",
    "mcp:serve": "ts-node tools/mcp/mmpm_mcp_server.ts",
    "mcp:serve:unsafe": "MMPM_MCP_ENABLE_MUTATIONS=1 ts-node tools/mcp/mmpm_mcp_server.ts",
    "setup": "npm install && npm run build && (test -f .env || cp .env.example .env) && echo 'Ready. Run: node dist/server.js  or  docker-compose up'",
    "skill:pack": "cd integrations && zip -r parametric-memory.skill claude-skill/ && echo 'Packaged integrations/parametric-memory.skill'"
  },
  "keywords": [
    "ai-memory",
    "merkle-tree",
    "markov-chain",
    "agent-memory",
    "mcp",
    "model-context-protocol",
    "leveldb",
    "cryptographic-proof",
    "fastify",
    "typescript"
  ],
  "author": "Glen Osborne",
  "license": "AGPL-3.0",
  "description": "Cryptographically verifiable, Markov-predictive memory substrate for AI agents. Every atom has a Merkle proof. Every access trains a prediction.",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "classic-level": "^3.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "prom-client": "^15.1.3"
  },
  "homepage": "https://parametric-memory.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjm2202/Parametric-Memory.git"
  },
  "bugs": {
    "url": "https://github.com/wjm2202/Parametric-Memory/issues"
  }
}
