{
  "name": "parametric-memory",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json --noEmit",
    "typecheck:all": "npm run typecheck",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "clean": "rm -rf dist",
    "cleanup": "ts-node tools/harness/cleanup.ts",
    "test": "vitest run",
    "posttest": "npm run cleanup",
    "test:watch": "vitest",
    "bench:ci:api": "bash tools/harness/ci-bench-api.sh",
    "bench:run": "ts-node tools/harness/cli.ts --preset smoke --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run": "npm run cleanup",
    "bench:run:api": "ts-node tools/harness/cli.ts --preset smoke --api --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "postbench:run:api": "npm run cleanup",
    "bench:slo:check": "ts-node tools/harness/slo_gate.ts --report-file tools/harness/results/latest.json",
    "bench:run:concurrent": "ts-node tools/harness/cli.ts --preset concurrent --out tools/harness/results/latest.json --prom-out tools/harness/results/latest.prom --print",
    "bench:track:save": "ts-node tools/harness/track.ts save --report-file tools/harness/results/latest.json --results-dir tools/harness/results",
    "bench:inspect:db": "ts-node tools/harness/inspect_db.ts --db ./mmpm-db --shard 0",
    "load:live": "ts-node tools/harness/continuous_client.ts --profile balanced --duration-ms 3600000 --target-ops 120 --concurrency 8 --metrics-port 9470 --metrics-host 0.0.0.0",
    "mcp:serve:readonly": "ts-node tools/mcp/mmpm_mcp_server.ts",
    "mcp:serve": "MMPM_MCP_ENABLE_MUTATIONS=1 ts-node tools/mcp/mmpm_mcp_server.ts",
    "mcp:serve:unsafe": "MMPM_MCP_ENABLE_MUTATIONS=1 MMPM_MCP_ENABLE_DANGEROUS=1 ts-node tools/mcp/mmpm_mcp_server.ts",
    "backup": "ts-node tools/backup.ts",
    "restore": "ts-node tools/restore.ts",
    "setup": "npm install && npm run build && (test -f .env || cp .env.example .env) && echo 'Ready. Edit .env then: ./start.sh'",
    "skill:pack": "cd integrations && zip -r parametric-memory.skill claude-skill/ && echo 'Packaged integrations/parametric-memory.skill'"
  },
  "keywords": [
    "ai-memory",
    "merkle-tree",
    "markov-chain",
    "agent-memory",
    "mcp",
    "model-context-protocol",
    "leveldb",
    "cryptographic-proof",
    "fastify",
    "typescript"
  ],
  "author": "Glen Osborne",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Cryptographically verifiable, Markov-predictive memory substrate for AI agents. Every atom has a Merkle proof. Every access trains a prediction.",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "classic-level": "^3.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "prom-client": "^15.1.3"
  },
  "homepage": "https://parametric-memory.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjm2202/Parametric-Memory.git"
  },
  "bugs": {
    "url": "https://github.com/wjm2202/Parametric-Memory/issues"
  }
}
