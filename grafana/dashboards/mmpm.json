{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "Prometheus",
            "description": "",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],
    "__requires": [
        {
            "type": "grafana",
            "id": "grafana",
            "name": "Grafana",
            "version": "9.0.0"
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": "1.0.0"
        },
        {
            "type": "panel",
            "id": "stat",
            "name": "Stat",
            "version": ""
        },
        {
            "type": "panel",
            "id": "timeseries",
            "name": "Time series",
            "version": ""
        }
    ],
    "annotations": {
        "list": []
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "title": "Access Rate",
            "description": "Requests per second to POST /access",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 8,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(rate(mmpm_access_total[1m]))",
                    "legendFormat": "req/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 100
                            },
                            {
                                "color": "red",
                                "value": 500
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            }
        },
        {
            "id": 2,
            "title": "Prediction Hit Rate",
            "description": "% of /access calls where Markov predicted the next atom",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 8,
                "x": 8,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "100 * sum(rate(mmpm_access_total{result=\"hit\"}[5m])) / sum(rate(mmpm_access_total[5m]))",
                    "legendFormat": "hit %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 40
                            },
                            {
                                "color": "green",
                                "value": 70
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "none"
            }
        },
        {
            "id": 3,
            "title": "P95 Latency",
            "description": "95th-percentile end-to-end /access latency",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 8,
                "x": 16,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.95, sum(rate(mmpm_request_duration_ms_bucket[5m])) by (le))",
                    "legendFormat": "P95 ms"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 50
                            },
                            {
                                "color": "red",
                                "value": 200
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            }
        },
        {
            "id": 4,
            "title": "Access Calls by Result",
            "description": "Rate of /access calls split by hit, miss and error",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 4
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (result) (rate(mmpm_access_total[1m]))",
                    "legendFormat": "{{result}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "gradientMode": "none",
                        "showPoints": "never"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "hit"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                }
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "miss"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "yellow"
                                }
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "error"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "red"
                                }
                            }
                        ]
                    }
                ]
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 5,
            "title": "Latency Percentiles",
            "description": "P50 / P95 / P99 of /access end-to-end latency",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 4
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.50, sum(rate(mmpm_request_duration_ms_bucket[5m])) by (le))",
                    "legendFormat": "P50"
                },
                {
                    "refId": "B",
                    "expr": "histogram_quantile(0.95, sum(rate(mmpm_request_duration_ms_bucket[5m])) by (le))",
                    "legendFormat": "P95"
                },
                {
                    "refId": "C",
                    "expr": "histogram_quantile(0.99, sum(rate(mmpm_request_duration_ms_bucket[5m])) by (le))",
                    "legendFormat": "P99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 0,
                        "showPoints": "never"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "P50"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "green"
                                }
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "P95"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "yellow"
                                }
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "P99"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "mode": "fixed",
                                    "fixedColor": "red"
                                }
                            }
                        ]
                    }
                ]
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 6,
            "title": "Train Rate",
            "description": "POST /train calls per second",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "rate(mmpm_train_total[1m])",
                    "legendFormat": "train req/s"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "blue"
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        },
        {
            "id": 7,
            "title": "Train Sequence Lengths",
            "description": "Distribution of sequence lengths passed to /train (P50/P95/P99)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 12
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.50, sum(rate(mmpm_train_sequence_length_bucket[5m])) by (le))",
                    "legendFormat": "P50 length"
                },
                {
                    "refId": "B",
                    "expr": "histogram_quantile(0.95, sum(rate(mmpm_train_sequence_length_bucket[5m])) by (le))",
                    "legendFormat": "P95 length"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5,
                        "showPoints": "never"
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 8,
            "title": "Node.js Heap Used",
            "description": "V8 heap memory currently in use",
            "type": "timeseries",
            "gridPos": {
                "h": 7,
                "w": 8,
                "x": 0,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "nodejs_heap_size_used_bytes",
                    "legendFormat": "heap used"
                },
                {
                    "refId": "B",
                    "expr": "nodejs_heap_size_total_bytes",
                    "legendFormat": "heap total"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5,
                        "showPoints": "never"
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            }
        },
        {
            "id": 9,
            "title": "Event Loop Lag",
            "description": "Node.js event loop delay (p99) — proxy for CPU starvation",
            "type": "timeseries",
            "gridPos": {
                "h": 7,
                "w": 8,
                "x": 8,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "nodejs_eventloop_lag_p99_seconds * 1000",
                    "legendFormat": "P99 lag ms"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "orange"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 50
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        },
        {
            "id": 10,
            "title": "Process CPU",
            "description": "CPU seconds consumed per second (1 = one full core)",
            "type": "timeseries",
            "gridPos": {
                "h": 7,
                "w": 8,
                "x": 16,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "rate(process_cpu_seconds_total[1m])",
                    "legendFormat": "CPU"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "purple"
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            }
        },
        {
            "id": 11,
            "title": "Trained Atoms",
            "description": "Atoms with at least one outgoing Markov transition recorded",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 12,
                "x": 0,
                "y": 27
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "mmpm_cluster_trained_atoms",
                    "legendFormat": "atoms"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            }
        },
        {
            "id": 12,
            "title": "Total Cluster Edges",
            "description": "Total trained Markov transitions across all shards",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 12,
                "x": 12,
                "y": 27
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "mmpm_cluster_total_edges",
                    "legendFormat": "edges"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "purple",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            }
        },
        {
            "id": 13,
            "title": "Prediction Confidence by Atom",
            "description": "Dominance ratio per atom: top_weight / total_weight. 1.0 = single deterministic successor, 0.5 = two equally-weighted paths. One line per atom — O(atoms) cardinality.",
            "type": "timeseries",
            "gridPos": {
                "h": 9,
                "w": 24,
                "x": 0,
                "y": 31
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "mmpm_atom_dominance_ratio",
                    "legendFormat": "{{atom}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5,
                        "showPoints": "never"
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            }
        },
        {
            "id": 14,
            "title": "Trained Edges per Atom (Out-degree)",
            "description": "Number of distinct successors each atom has learned. Flat line = converged. Rising line = new paths being discovered.",
            "type": "timeseries",
            "gridPos": {
                "h": 9,
                "w": 24,
                "x": 0,
                "y": 40
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "mmpm_atom_trained_edges",
                    "legendFormat": "{{atom}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "min": 0,
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5,
                        "showPoints": "never",
                        "drawStyle": "line",
                        "stacking": {
                            "mode": "none"
                        }
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "right"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            }
        }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "tags": [
        "mmpm",
        "markov",
        "merkle"
    ],
    "templating": {
        "list": [
            {
                "current": {},
                "hide": 0,
                "includeAll": false,
                "label": "Data Source",
                "multi": false,
                "name": "DS_PROMETHEUS",
                "options": [],
                "query": "prometheus",
                "refresh": 1,
                "type": "datasource"
            }
        ]
    },
    "time": {
        "from": "now-30m",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "MMPM — Markov Merkle Predictive Memory",
    "uid": "mmpm-main",
    "version": 1
}